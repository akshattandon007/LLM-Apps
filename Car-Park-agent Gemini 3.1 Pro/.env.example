# ──────────────────────────────────────────────
# ParkMate AI — Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env and fill in your keys.
#   cp .env.example .env
#
# Then load them:
#   export $(grep -v '^#' .env | xargs)

# REQUIRED — Google AI Studio (https://aistudio.google.com/apikey)
# Note: Gemini 3.1 Pro requires a paid plan.
# The agent auto-falls back to Gemini 3 Flash (free tier) if needed.
GEMINI_API_KEY=your_gemini_api_key_here

# REQUIRED — Google Cloud Console → APIs & Services → Maps Platform
# Enable these 3 APIs: Geocoding API, Places API (New), Routes API
# Get key from: Credentials → Create Credentials → API Key
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# OPTIONAL — Parkopedia (enterprise-only, https://business.parkopedia.com)
# If not set, the agent uses curated fallback data for major UK cities.
# This is perfectly fine for demos and development.
PARKOPEDIA_API_KEY=
PARKOPEDIA_API_ID=
