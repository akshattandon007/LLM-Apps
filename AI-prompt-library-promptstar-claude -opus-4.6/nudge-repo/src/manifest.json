{
  "manifest_version": 3,
  "name": "Nudge",
  "version": "1.0.0",
  "description": "Nudge — your friendly prompt template library. Invoke with Alt+P.",
  "permissions": ["activeTab", "scripting", "storage"],
  "commands": {
    "toggle-palette": {
      "suggested_key": {
        "default": "Alt+P",
        "mac": "Alt+P"
      },
      "description": "Toggle Nudge"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["templates.js", "content.js"],
      "css": ["styles.css"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    },
    "default_title": "Nudge (Alt+P)"
  },
  "host_permissions": ["https://api.anthropic.com/*"]
}
